{
  "name": "lazy-dom",
  "version": "0.1.0",
  "description": "Lazy HTML DOM implementation for fast tests",
  "main": "dist/lazyDom.js",
  "types": "./dist/lazyDom.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lazyDom.d.ts",
      "default": "./dist/lazyDom.js"
    },
    "./register": "./dist/register.js",
    "./utils/invariant": {
      "types": "./dist/utils/invariant.d.ts",
      "default": "./dist/utils/invariant.js"
    }
  },
  "typesVersions": {
    "*": {
      "utils/invariant": [
        "dist/utils/invariant.d.ts"
      ]
    }
  },
  "scripts": {
    "benchmark:watch": "tsx watch src/benchmark/benchmark.ts",
    "benchmark": "pnpm build:wasm && tsx src/benchmark/benchmark.ts",
    "build:wasm": "asc src/assembly/index.ts --outFile build/wasm/lazy-dom.wasm --optimize --exportRuntime",
    "build": "pnpm build:wasm && tsc -p tsconfig.build.json",
    "build:watch": "pnpm exec tsc --watch ./src/lazyDom.ts --outDir dist",
    "dev:watch": "nodemon --config nodemon.dev.json",
    "dev": "pnpm benchmark && pnpm test",
    "test:jsdom": "echo '*** JSDOM ***'; tsx --import global-jsdom/register ./node_modules/mocha/bin/mocha.js || (echo '*** failure in JSDOM test ***' && exit -1)",
    "test:lazydom": "echo '*** lazyDom ***'; pnpm build:wasm && tsx --import ./src/register.ts ./node_modules/mocha/bin/mocha.js || (echo '*** failure in lazyDom test ***' && exit -1)",
    "test:watch": "nodemon --config nodemon.test.json --",
    "test": "pnpm test:jsdom && pnpm test:lazydom",
    "typecheck": "pnpm tsc --noEmit"
  },
  "keywords": [],
  "author": "Michael Zedeler <michael@zedeler.dk>",
  "license": "MIT",
  "dependencies": {
    "@assemblyscript/loader": "^0.28.9",
    "css-select": "^5.1.0",
    "htmlparser2": "^10.1.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.1.0",
    "@types/chai": "^4.3.16",
    "@types/jsdom": "^21.1.6",
    "@types/lodash-es": "^4.17.12",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^3.2.12",
    "assemblyscript": "^0.28.9",
    "chai": "^5.2.0",
    "global-jsdom": "^24.0.0",
    "jsdom": "^24.0.0",
    "lodash-es": "^4.17.21",
    "mocha": "^10.4.0",
    "nanoid": "^5.0.7",
    "nodemon": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sinon": "^18.0.0",
    "sinon-chai": "^3.7.0",
    "source-map-support": "^0.5.21",
    "tinybench": "^2.8.0",
    "tsx": "^4.11.0",
    "typescript": "^5.6.2"
  }
}
